# 应用
# APP_ENV 可选值：development（本地开发）| production（生产）
# OSS 上传路径会根据此值自动切换：
#   development → filmgenx/dev/...
#   production  → filmgenx/prod/...
APP_ENV=production
SECRET_KEY=change-me-in-production

# Docker Compose 会读取下面这组 PostgreSQL 账号，
# 并自动给 backend / worker 组装容器内可用的 DATABASE_URL
POSTGRES_DB=filmgenx
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 数据库
# 本地直接运行后端时，如需宿主机连接数据库，可改为 localhost
# Docker Compose 启动时会自动覆盖成容器内的 postgres 地址
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/filmgenx

# Redis（任务队列）
# 本地直接运行后端时，如需宿主机连接 Redis，可改为 localhost
# Docker Compose 启动时会自动覆盖成容器内的 redis 地址
REDIS_URL=redis://redis:6379/0

# AI 服务
EVOLINK_API_KEY=your-evolink-api-key
EVOLINK_BASE_URL=https://api.evolink.ai

# Google
GOOGLE_API_KEY=your-google-api-key

# 本地文件存储（开发环境备用）
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=100

# 阿里云 OSS
# Endpoint 示例：https://oss-cn-hangzhou.aliyuncs.com
# 各地域 Endpoint 参考：https://help.aliyun.com/document_detail/31837.html
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# 所有文件的根目录前缀，同一个 Bucket 多项目共用时用于隔离
OSS_BASE_DIR=filmgenx
# 可选：绑定了 CDN 域名时填写，留空则使用 OSS 默认域名
# 示例：https://cdn.yourdomain.com
OSS_CDN_DOMAIN=

# 邀请码（留空则不校验，生产环境必须设置）
INVITE_CODE=your-invite-code
